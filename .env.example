# Copie para .env.local e preencha os valores. Não commite .env.local.

# --- App ---
# NEXT_PUBLIC_SITE_URL=https://www.exemplo.pt

# --- Resend (email) ---
# RESEND_API_KEY=
# RESEND_FROM_EMAIL="Escritório <noreply@dominio.com>"
# CONTACT_TO_EMAIL=destino@dominio.com

# --- Base de dados (ex.: Vercel Postgres / Neon) — adicionar quando integrado ---
# POSTGRES_URL=

# --- Redis / KV (opcional: cache, rate limit) ---
# REDIS_URL=

# --- Autenticação (adicionar conforme biblioteca escolhida: Auth.js, Clerk, etc.) ---
# AUTH_SECRET=
