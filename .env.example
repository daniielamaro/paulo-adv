# Copie para .env.local e preencha os valores. Não commite .env.local.

# --- App (obrigatório em produção para SEO: canónico, Open Graph, sitemap, JSON-LD) ---
# NEXT_PUBLIC_SITE_URL=https://www.exemplo.com.br

# --- Resend (email) ---
# RESEND_API_KEY=
# RESEND_FROM_EMAIL="Escritório <noreply@dominio.com>"
# CONTACT_TO_EMAIL=destino@dominio.com

# --- Base de dados (Postgres: Vercel Marketplace / Neon) ---
# POSTGRES_URL=  # obrigatório em .env.local para npm run db:push / db:studio

# --- Auth.js (sessão JWT; área /admin) ---
# AUTH_SECRET=  # gere com: openssl rand -base64 32
# AUTH_URL=http://localhost:3000
# Em produção na Vercel: AUTH_URL=https://seu-dominio.vercel.app

# --- Semente do primeiro administrador (só correr localmente, depois remover do .env) ---
# ADMIN_SEED_EMAIL=voce@exemplo.com
# ADMIN_SEED_PASSWORD=
# ADMIN_SEED_NAME=Nome

# --- Redis / KV (opcional: cache, rate limit) ---
# REDIS_URL=
